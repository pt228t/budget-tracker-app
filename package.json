{
  "name": "budgetpulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "deploy:gs": "node scripts/deploy-apps-script.mjs",
    "deploy:gs:dry": "node scripts/deploy-apps-script.mjs --dry-run",
    "clasp:login": "clasp login",
    "dev:agent": "vite --host 127.0.0.1 --port 4173 & echo 'Dev server starting at http://127.0.0.1:4173 — open Claude Code in this dir to use Playwright MCP'"
  },
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "@playwright/test": "^1.54.1",
    "@testing-library/dom": "^10.4.0",
    "jsdom": "^26.1.0",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
